{
  "name": "impi-src",
  "version": "1.5.2",
  "private": true,
  "description": "IMPI source code workspace",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.17.0+sha512.fce8a3dd29a4ed2ec566fb53efbb04d8c44a0f05bc6f24a73046910fb9c3ce7afa35a0980500668fa3573345bd644644fa98338fa168235c80f4aa17aa17fbef",
  "scripts": {
    "setup": "node scripts/ensure-pnpm.js && pnpm install",
    "build": "pnpm --filter './libs/**' run build",
    "build:angular": "pnpm --filter angular run build",
    "build:electron": "pnpm --filter impi run build",
    "build:cli": "pnpm --filter impi-cli run build",
    "build:all": "pnpm run build && pnpm run build:angular && pnpm run build:electron",
    "test": "pnpm --filter './libs/**' run test",
    "test:angular": "pnpm --filter angular run test",
    "test:all": "pnpm run test && pnpm run test:angular",
    "clean": "pnpm --filter './libs/**' run clean",
    "lint": "pnpm --filter './libs/**' run lint",
    "typecheck": "pnpm --filter './libs/**' run typecheck",
    "dev": "pnpm run build && pnpm run test",
    "check-pnpm": "node scripts/ensure-pnpm.js",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint-formatter-compact": "^8.40.0",
    "typescript": "^5.3.3"
  }
}
