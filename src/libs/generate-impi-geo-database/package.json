{
  "name": "generate-impi-geo-database",
  "version": "1.5.2",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://git.softrain.ch/impi.git"
  },
  "author": "BFS <impi@bfs.admin.ch>",
  "license": "ISC",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "pnpm run clean",
    "build": "tsc",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "bump": "pnpm version patch",
    "tsc": "tsc",
    "build_win32": "pkg . --targets win-x86"
  },
  "description": "Generate the IMPI sqlite3 db from csv files",
  "dependencies": {
    "normalize-common": "workspace:*",
    "csv-parse": "^5.5.2",
    "csv-stringify": "catalog:",
    "iconv-lite": "catalog:",
    "stream-transform": "catalog:",
    "better-sqlite3": "catalog:",
    "sqlite3": "catalog:",
    "commander": "catalog:",
    "ora": "catalog:",
    "picocolors": "^1.1.0",
    "winston": "catalog:",
    "normalize-city": "workspace:*",
    "normalize-street": "workspace:*"
  },
  "devDependencies": {
    "@types/chai": "catalog:testing",
    "@types/mocha": "catalog:testing",
    "@types/node": "catalog:",
    "chai": "catalog:testing",
    "mocha": "catalog:testing",
    "nyc": "catalog:testing",
    "rimraf": "catalog:",
    "ts-node": "catalog:",
    "typescript": "catalog:lang",
    "@types/uuid": "catalog:",
    "@types/archiver": "catalog:",
    "@types/better-sqlite3": "catalog:"
  },
  "bin": {
    "generate-impi-db": "dist/generate-impi-db-cli.js"
  }
}