{
  "name": "impi-libs-workspace",
  "version": "1.5.2",
  "private": true,
  "description": "Workspace for IMPI library packages",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "clean": "pnpm -r run clean",
    "lint": "eslint **/*.ts",
    "lint:fix": "eslint **/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "build:all": "pnpm run clean && pnpm run build",
    "test:all": "pnpm run build:all && pnpm run test",
    "install:all": "pnpm install"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "catalog:eslint",
    "@typescript-eslint/parser": "catalog:eslint",
    "eslint": "catalog:eslint",
    "typescript": "catalog:lang"
  },
  "pnpm": {
    "overrides": {
      "graceful-fs": "^4.2.11"
    }
  }
}